    {
      "name": "Login",
      "item": [
        {
          "name": "Start",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body?.data?.sessionId) pm.environment.set('sessionId', body.data.sessionId);",
                  "if (body?.data?.authorizeUrl) pm.environment.set('authorizeUrl', body.data.authorizeUrl);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/login/start?prompt=select_account",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "login",
                "start"
              ],
              "query": [
                {
                  "key": "prompt",
                  "value": "select_account"
                }
              ]
            },
            "description": "Inicia el flujo OAuth. Guarda sessionId y authorizeUrl en el environment."
          }
        },
        {
          "name": "Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/login/status/{{sessionId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "login",
                "status",
                "{{sessionId}}"
              ]
            },
            "description": "Consulta el estado actual del login usando la sessionId guardada."
          }
        },
        {
          "name": "Callback",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/login/callback?state={{sessionId}}&code={{callbackCode}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "login",
                "callback"
              ],
              "query": [
                {
                  "key": "state",
                  "value": "{{sessionId}}"
                },
                {
                  "key": "code",
                  "value": "{{callbackCode}}"
                }
              ]
            },
            "description": "Normalmente esta ruta la llama Microsoft al redirigir. Se deja para pruebas manuales."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearerToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/login/logout",
