              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body?.data?.id) pm.environment.set('bannerId', body.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearerToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"slug\": \"home-launcher-main\",\n  \"title\": \"Banner principal\",\n  \"subtitle\": \"Probando Postman\",\n  \"imageUrl\": \"https://example.com/banner.png\",\n  \"mobileImageUrl\": \"https://example.com/banner-mobile.png\",\n  \"targetUrl\": \"https://mclaunch.app\",\n  \"placement\": \"home\",\n  \"variant\": \"hero\",\n  \"isActive\": true,\n  \"sortOrder\": 1,\n  \"startsAt\": null,\n  \"endsAt\": null,\n  \"metadata\": {\n    \"source\": \"postman\"\n  }\n}",
              "options": {
