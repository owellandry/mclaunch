{
  "name": "mclaunch",
  "version": "0.1.0",
  "private": true,
  "description": "Slaumcher, launcher de Minecraft con React + Electron",
  "main": "dist-electron/main.js",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "predev": "node scripts/predev.cjs",
    "dev:api": "bun --watch backend/src/index.ts",
    "start:api": "bun backend/src/index.ts",
    "typecheck:api": "tsc -p backend/tsconfig.json --noEmit",
    "dev:ui": "pnpm --dir react-ui dev",
    "dev:electron": "wait-on tcp:5173 && pnpm build:electron && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 node scripts/run-electron.cjs .",
    "dev": "node scripts/dev.mjs",
    "dev:installer": "pnpm --dir react-installer dev",
    "build:ui": "pnpm --dir react-ui build",
    "build:installer": "pnpm --dir react-installer build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "pnpm build:ui && pnpm build:electron",
    "start": "node scripts/run-electron.cjs .",
    "dist": "pnpm build && electron-builder",
    "dist:local": "node scripts/dist-local.cjs"
  },
  "build": {
    "appId": "com.mclaunch.app",
    "productName": "Slaumcher",
    "files": [
      "dist-electron/**/*",
      "react-ui/dist/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/uninstallerIcon.ico",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "installerHeader": "build/installerHeader.bmp",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Slaumcher",
      "include": "build/installer.nsh"
    },
    "win": {
      "artifactName": "Slaumcher-${version}-windows-${arch}.${ext}",
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "artifactName": "Slaumcher-${version}-macos-${arch}.${ext}",
      "target": [
        "zip"
      ]
    },
    "linux": {
      "artifactName": "Slaumcher-${version}-linux-${arch}.${ext}",
      "target": [
        "AppImage"
      ]
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "41.1.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.2",
    "wait-on": "^9.0.4"
  },
  "workspaces": [
    "react-ui",
    "react-installer"
  ],
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.4.2",
    "minecraft-launcher-core": "^3.18.2",
    "msmc": "^5.0.5",
    "pg": "^8.20.0",
    "redis": "^5.11.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "electron-winstaller"
    ],
    "overrides": {
      "axios": "^1.15.0"
    }
  }
}
